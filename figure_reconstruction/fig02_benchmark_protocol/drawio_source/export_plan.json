{
  "report": "drawio_export_report.json",
  "calls": [
    {
      "name": "drawio_validate",
      "arguments": {
        "input_path": "${PLAN_DIR}/fig02_protocol_hierarchy.drawio"
      },
      "timeout_ms": 30000
    },
    {
      "name": "drawio_export",
      "arguments": {
        "input_path": "${PLAN_DIR}/fig02_protocol_hierarchy.drawio",
        "format": "png",
        "output_path": "${PLAN_DIR}/fig02_protocol_hierarchy.png",
        "width": 2400,
        "border": 15,
        "transparent": false,
        "embed": false,
        "overwrite": true
      },
      "timeout_ms": 180000
    },
    {
      "name": "drawio_export",
      "arguments": {
        "input_path": "${PLAN_DIR}/fig02_protocol_hierarchy.drawio",
        "format": "svg",
        "output_path": "${PLAN_DIR}/fig02_protocol_hierarchy.svg",
        "border": 15,
        "transparent": false,
        "embed": true,
        "overwrite": true
      },
      "timeout_ms": 180000
    },
    {
      "name": "drawio_export",
      "arguments": {
        "input_path": "${PLAN_DIR}/fig02_protocol_hierarchy.drawio",
        "format": "pdf",
        "output_path": "${PLAN_DIR}/fig02_protocol_hierarchy.pdf",
        "border": 15,
        "embed": true,
        "overwrite": true
      },
      "timeout_ms": 180000
    }
  ]
}
